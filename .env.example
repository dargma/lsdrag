# .env.example — 실제 .env는 반드시 .gitignore. 키 평문 커밋 금지.
# 복사: cp .env.example .env   그 후 값 채우기

# Upstage Document Parse (파서) — 사용자 환경에서 이미 쓰는 이름
UP_TOKEN=

# Reader(LLM/VLM) — config.yaml의 reader.provider로 선택.
# provider: claude_code (기본) → 로컬 claude CLI 사용, 아래 키 불필요(비워둬도 됨)
# provider: openai  → OPENAI_API_KEY 필요
OPENAI_API_KEY=
# provider: anthropic → ANTHROPIC_API_KEY 필요
ANTHROPIC_API_KEY=
