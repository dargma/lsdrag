# .env.example — 실제 .env는 반드시 .gitignore. 키 평문 커밋 금지.
# 복사: cp .env.example .env   그 후 값 채우기

# Upstage Document Parse (파서) — 사용자 환경에서 이미 쓰는 이름
UP_TOKEN=

# Reader(LLM/VLM) — config.yaml의 reader.provider로 하나 선택, 해당 키만 채우면 됨
# provider: openai  → 아래 OPENAI_API_KEY
OPENAI_API_KEY=
# provider: anthropic(claude) → 아래 ANTHROPIC_API_KEY (Claude Code에서 쓰는 모델)
ANTHROPIC_API_KEY=
